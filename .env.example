# Secure File Sharing System - Environment Variables

# App Settings
APP_NAME=SecureFileShare
DEBUG=False
SECRET_KEY=change-this-to-a-256-bit-random-key-in-production

# Database
DATABASE_URL=sqlite:///./secure_file_sharing.db
# For PostgreSQL: postgresql://user:password@localhost/secure_file_sharing

# JWT Settings
JWT_SECRET_KEY=change-this-to-a-different-256-bit-random-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# Encryption
AES_KEY_SIZE=32
RSA_KEY_SIZE=2048

# Key Storage
KEYS_DIR=./keys
